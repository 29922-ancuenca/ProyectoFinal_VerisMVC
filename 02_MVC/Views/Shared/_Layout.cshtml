<!DOCTYPE html>
<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Cl&iacute;nica Veris</title>
    @Styles.Render("~/Content/css")
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @Scripts.Render("~/bundles/modernizr")
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f4fa;
            margin: 0; padding: 0;
        }

        /* ── NAVBAR ── */
        .navbar-veris {
            background: linear-gradient(90deg, #040e22 0%, #0b1d3e 55%, #162d55 100%);
            box-shadow: 0 2px 20px rgba(4,14,34,0.6);
            padding: 0.6rem 0;
        }
        .navbar-veris .brand-wrap {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none; color: #fff;
        }
        .navbar-veris .brand-icon {
            width: 42px; height: 42px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; flex-shrink: 0;
        }
        .navbar-veris .brand-name {
            font-size: 1.1rem; font-weight: 800;
            letter-spacing: 0.4px; line-height: 1.2; color: #fff;
        }
        .navbar-veris .brand-sub {
            font-size: 0.55rem; letter-spacing: 3px;
            text-transform: uppercase; color: rgba(255,255,255,0.5);
        }
        .navbar-veris .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500; font-size: 0.88rem;
            padding: 0.42rem 0.85rem !important;
            border-radius: 50px;
            transition: background .2s, color .2s;
            display: inline-flex; align-items: center; gap: 5px;
        }
        .navbar-veris .nav-link:hover {
            background: rgba(255,255,255,0.14);
            color: #fff !important;
        }
        .navbar-veris .navbar-toggler { border: none; }
        .navbar-veris .navbar-toggler:focus { box-shadow: none; }

        /* ── Registrarse / Iniciar sesi&oacute;n links ── */
        #registerLink {
            border: 1.5px solid rgba(255,255,255,0.65) !important;
            border-radius: 50px !important;
            padding: 0.35rem 1.2rem !important;
            font-size: 0.85rem !important;
            font-weight: 600 !important;
            transition: all .2s;
        }
        #registerLink:hover {
            background: rgba(255,255,255,0.9) !important;
            color: #0b1d3e !important;
        }
        #loginLink {
            font-size: 0.88rem !important;
            font-weight: 500;
            opacity: 0.85;
        }

        /* ── BODY ── */
        .body-content { padding: 0; }

        /* ── FOOTER ── */
        .veris-footer {
            background: #040e22;
            color: rgba(255,255,255,0.4);
            text-align: center;
            padding: 1rem 0;
            font-size: 0.78rem;
        }
        .veris-footer strong { color: rgba(255,255,255,0.75); }
    </style>
</head>
<body>

<!-- ══════════ NAVBAR ══════════ -->
<nav class="navbar navbar-expand-lg navbar-veris sticky-top">
    <div class="container-fluid px-4">

        <a class="brand-wrap" href="@Url.Action("Index", "Home")">
            <div class="brand-icon">
                <i class="bi bi-hospital-fill text-white"></i>
            </div>
            <div>
                <div class="brand-name">Cl&iacute;nica Veris</div>
                <div class="brand-sub">Cobertura M&eacute;dica Integral</div>
            </div>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                data-bs-target="#navbarVeris" aria-expanded="false" aria-label="Men&uacute;">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarVeris">
            <ul class="navbar-nav mx-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-person-fill"></i>M&oacute;dulo Paciente
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-heart-pulse-fill"></i>M&oacute;dulo M&eacute;dico
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-shield-fill-check"></i>M&oacute;dulo Administrador
                    </a>
                </li>
            </ul>

            <div class="d-flex align-items-center">
                @Html.Partial("_LoginPartial")
            </div>
        </div>

    </div>
</nav>

<!-- ══════════ BODY ══════════ -->
<div class="body-content">
    @RenderBody()
</div>

<!-- ══════════ FOOTER ══════════ -->
<footer class="veris-footer">
    <strong>Cl&iacute;nica Veris</strong> &mdash; Grupo 03 &mdash;
    &copy; @DateTime.Now.Year Universidad de las Fuerzas Armadas ESPE
</footer>

@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/bootstrap")
@RenderSection("scripts", required: false)
</body>
</html>
