@using Microsoft.AspNet.Identity
<!DOCTYPE html>
<html lang="es">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <title>@ViewBag.Title - Proyecto Veris</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f4fa;
            margin: 0;
            padding: 0;
        }

        .navbar-veris {
            background: #fff;
            box-shadow: 0 4px 18px rgba(0,0,0,.08);
            padding: .55rem 0;
        }

            .navbar-veris .brand-wrap {
                display: flex;
                align-items: center;
                text-decoration: none;
            }

            .navbar-veris .nav-link {
                color: #0b1d3e !important;
                font-weight: 600;
                font-size: .9rem;
                padding: .45rem 1rem !important;
                border-radius: 50px;
                transition: all .2s ease;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

                .navbar-veris .nav-link:hover {
                    background: #e8f0fe;
                    color: #0d6efd !important;
                }

            .navbar-veris .navbar-toggler {
                border: none;
            }

                .navbar-veris .navbar-toggler:focus {
                    box-shadow: none;
                }

        .body-content {
            padding: 0;
            min-height: 70vh;
        }

        .footer-veris {
            margin-top: 3rem;
        }

        .footer-top {
            background: #0d6efd;
        }

            .footer-top h6 {
                font-weight: 600;
            }

        .social-icon {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,.18);
            color: #fff;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 1.1rem;
            transition: all .2s ease;
        }

            .social-icon:hover {
                background: #fff;
                color: #0d6efd;
                transform: translateY(-2px);
            }

        .footer-bottom {
            background: #0b1d3e;
            font-size: .85rem;
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            background: #0d6efd;
            color: #fff;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            margin-right: 10px;
        }

            .brand-icon i {
                color: #fff;
                font-size: 1.3rem;
            }

        .brand-name {
            font-weight: 800;
            color: #0b1d3e;
            font-size: 1rem;
            line-height: 1.1;
        }

        .brand-sub {
            font-size: .72rem;
            color: #64748b;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-veris sticky-top">
        <div class="container-fluid px-4">

            <a class="brand-wrap" href="@Url.Action("Index", "Home")">
                <div class="brand-icon">
                    <i class="bi bi-hospital-fill"></i>
                </div>
                <div>
                    <div class="brand-name">Cl&iacute;nica Veris</div>
                    <div class="brand-sub">Cobertura M&eacute;dica Integral</div>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarVeris" aria-controls="navbarVeris"
                    aria-expanded="false" aria-label="Alternar navegaci&oacute;n">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-between" id="navbarVeris">

                <ul class="navbar-nav flex-grow-1 justify-content-evenly text-center">

                    @if (!Request.IsAuthenticated)
                    {
                        if (ViewBag.Modulo == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Login", "Account", new { modulo = "Paciente" })">M&oacute;dulo Paciente</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Login", "Account", new { modulo = "Medico" })">M&oacute;dulo M&eacute;dico</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Login", "Account", new { modulo = "Administrador" })">M&oacute;dulo Administrador</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Login", "Account")">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Register", "Account")">Register</a>
                            </li>
                        }
                    }
                    else if (User.IsInRole("SuperAdmin"))
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "paciente")"><i class="bi bi-people-fill me-1"></i>Pacientes</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "medico")"><i class="bi bi-person-badge-fill me-1"></i>M&eacute;dicos</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "especialidades")"><i class="bi bi-award-fill me-1"></i>Especialidades</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "medicamentos")"><i class="bi bi-capsule me-1"></i>Medicamentos</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "consultas")"><i class="bi bi-calendar2-check-fill me-1"></i>Consultas</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "recetas")"><i class="bi bi-file-earmark-medical-fill me-1"></i>Recetas</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Rol")"><i class="bi bi-shield-lock-fill me-1"></i>Gesti&oacute;n de Roles</a></li>
                    }
                    else if (User.IsInRole("Administrador"))
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "paciente")"><i class="bi bi-people-fill me-1"></i>Pacientes</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "medico")"><i class="bi bi-person-badge-fill me-1"></i>M&eacute;dicos</a></li>
                    }
                    else if (User.IsInRole("Medico"))
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "medico")"><i class="bi bi-person-badge-fill me-1"></i>Mis Datos</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "consultas")"><i class="bi bi-calendar2-check-fill me-1"></i>Consultas</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "recetas")"><i class="bi bi-file-earmark-medical-fill me-1"></i>Recetas</a></li>
                    }
                    else if (User.IsInRole("Paciente"))
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "paciente")"><i class="bi bi-person-circle me-1"></i>Mis Datos</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "AgendarCita")"><i class="bi bi-calendar-plus-fill me-1"></i>Agendar Cita</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "consultas")"><i class="bi bi-calendar2-check-fill me-1"></i>Mis Consultas</a></li>
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "recetas")"><i class="bi bi-file-earmark-medical-fill me-1"></i>Mis Recetas</a></li>
                    }

                </ul>

                <div class="d-flex gap-2 align-items-center">
                    @if (!Request.IsAuthenticated)
                    {
                        <a href="@Url.Action("Register", "Account")" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                            <i class="bi bi-person-plus-fill me-1"></i>Registrarse
                        </a>
                        <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-sm rounded-pill px-3">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesi&oacute;n
                        </a>
                    }
                    else
                    {
                        <span class="fw-semibold text-dark me-1">
                            <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                        </span>
                        <form action="@Url.Action("LogOff", "Account")" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesi&oacute;n
                            </button>
                        </form>
                    }
                </div>

            </div>

        </div>
    </nav>

    <!-- BODY -->
    <main class="body-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer-veris">
        <div class="footer-top text-center text-white py-3">
            <h6 class="mb-2">Encuentra nuestras redes sociales</h6>
            <div class="d-flex justify-content-center gap-3">
                <a href="#" class="social-icon"><i class="bi bi-whatsapp"></i></a>
                <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                <a href="#" class="social-icon"><i class="bi bi-twitter-x"></i></a>
                <a href="#" class="social-icon"><i class="bi bi-youtube"></i></a>
            </div>
        </div>
        <div class="footer-bottom text-center text-white py-3">
            &copy; @DateTime.Now.Year - Proyecto HUMANAS | Todos los derechos reservados | Desarrollado por Grupo 03
        </div>
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

</body>
</html>
