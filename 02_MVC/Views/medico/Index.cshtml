@model IEnumerable<_02_MVC.Models.medicos>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .med-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,.07);
        overflow: hidden;
    }

    .med-table thead {
        background: #0b1d3e;
        color: #fff;
    }

    .med-table thead th {
        font-weight: 600;
        font-size: .83rem;
        padding: .9rem 1rem;
        border: none;
    }

    .med-table tbody tr:hover {
        background: #f5f8ff;
    }

    .med-table td {
        padding: .75rem 1rem;
        vertical-align: middle;
        border-color: #f0f0f0;
        font-size: .9rem;
    }
</style>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="bi bi-person-badge-fill text-primary me-2"></i>M&eacute;dicos
        </h2>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrador"))
        {
            <p class="mb-0"><a href="@Url.Action("Create", "medico")" class="btn btn-primary rounded-pill px-4">Nuevo Médico</a></p>
        }
    </div>

    <div class="med-card card">
        <div class="card-body p-0">
            <table class="table med-table align-middle mb-0">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Nombre)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Foto)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.AspNetUsers.Email)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.especialidades.Descripcion)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Nombre)
        </td>
        <td>
            @if (!string.IsNullOrEmpty(item.Foto))
            {
                <img src="~/imágenes/sellos/@item.Foto" style="width:48px; height:48px; object-fit:cover; border-radius:50%; border:2px solid #e2e8f0;" alt="foto" />
            }
            else
            {
                <i class="bi bi-person-circle" style="font-size:2rem; color:#0d6efd;"></i>
            }
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.AspNetUsers.Email)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.especialidades.Descripcion)
        </td>
        <td>
            @Html.ActionLink("Details", "Details", new { id = item.IdMedico })
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrador"))
            {
                @: | @Html.ActionLink("Edit", "Edit", new { id = item.IdMedico })
                @: | @Html.ActionLink("Delete", "Delete", new { id = item.IdMedico })
            }
        </td>
    </tr>
}

            </table>
        </div>
    </div>
</div>
