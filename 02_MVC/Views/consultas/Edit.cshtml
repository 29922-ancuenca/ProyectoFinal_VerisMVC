@model _02_MVC.Models.consultas

@{
    ViewBag.Title = "Atender Consulta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .edit-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 6px 28px rgba(0,0,0,.08);
        overflow: hidden;
        max-width: 680px;
        margin: 2rem auto;
    }

    .edit-card-header {
        background: #0b1d3e;
        color: #fff;
        padding: 1.2rem 2rem;
    }

        .edit-card-header h4 {
            margin: 0;
            font-weight: 700;
            font-size: 1.1rem;
        }

    .edit-card .card-body {
        padding: 2rem;
    }

    .edit-card .form-group label {
        font-weight: 600;
        color: #0b1d3e;
        font-size: .88rem;
    }

    .edit-card .form-control {
        border-radius: 10px;
        border: 1px solid #cbd5e1;
    }

        .edit-card .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 .2rem rgba(13,110,253,.15);
        }

    .btn-guardar {
        background: #0d6efd;
        color: dodgerblue;
        border: none;
        border-radius: 50px;
        padding: .6rem 2rem;
        font-weight: 700;
    }

        .btn-guardar:hover {
            background: #0b5ed7;
            color: #fff;
        }
</style>

@using (Html.BeginForm("Atender", "consultas", new { id = Model.IdConsulta }, FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="edit-card card">
        <div class="edit-card-header">
            <h4><i class="bi bi-clipboard2-pulse-fill me-2"></i>Atender Consulta</h4>
        </div>
        <div class="card-body">
            <div class="form-horizontal">
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="form-group">
                    <label class="control-label col-md-2">Paciente</label>
                    <div class="col-md-10">
                        <input type="text" class="form-control" value="@(Model.pacientes != null ? Model.pacientes.Nombre : "-")" readonly />
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">Fecha</label>
                    <div class="col-md-10">
                        <input type="text" class="form-control" value="@Model.FechaConsulta.ToString("dd/MM/yyyy")" readonly />
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">Hora Inicio</label>
                    <div class="col-md-10">
                        <input type="text" class="form-control" value="@Model.HI.ToString(@"hh\:mm")" readonly />
                    </div>
                </div>

                <div class="form-group">
                    <label class="control-label col-md-2">Hora Fin</label>
                    <div class="col-md-10">
                        <input type="text" class="form-control" value="@Model.HF.ToString(@"hh\:mm")" readonly />
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Diagnostico, htmlAttributes: new { @class = "control-label col-md-2" })
                    <div class="col-md-10">
                        @Html.TextAreaFor(model => model.Diagnostico, new { @class = "form-control", rows = "4" })
                        @Html.ValidationMessageFor(model => model.Diagnostico, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <div class="col-md-offset-2 col-md-10">
                        <input type="submit" value="Guardar" class="btn btn-guardar" />
                        @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4 ms-2" })
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
