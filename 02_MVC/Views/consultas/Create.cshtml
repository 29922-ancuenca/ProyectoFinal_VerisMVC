@model _02_MVC.Models.consultas

@{
    ViewBag.Title = "Nueva Consulta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 6px 28px rgba(0,0,0,.08);
        overflow: hidden;
        max-width: 680px;
        margin: 0 auto;
    }
    .form-card-header {
        background: #0b1d3e;
        color: #fff;
        padding: 1.4rem 2rem;
    }
    .form-card-header h4 {
        margin: 0;
        font-weight: 700;
        font-size: 1.15rem;
    }
    .form-card-body {
        padding: 2rem;
        background: #fff;
    }
    .form-label-custom {
        font-weight: 600;
        color: #0b1d3e;
        font-size: .88rem;
        margin-bottom: .3rem;
    }
    .form-control-custom {
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        padding: .65rem 1rem;
        font-size: .9rem;
    }
    .form-control-custom:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 .2rem rgba(13,110,253,.15);
    }
    .btn-guardar {
        background: #0d6efd;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: .6rem 2rem;
        font-weight: 700;
        transition: all .2s ease;
    }
    .btn-guardar:hover {
        background: #0b5ed7;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(13,110,253,.3);
    }
</style>

<div class="container my-5">

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-card card">
            <div class="form-card-header">
                <h4><i class="bi bi-calendar2-plus-fill me-2"></i>Nueva Consulta</h4>
            </div>
            <div class="form-card-body">

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <div class="mb-3">
                    <label class="form-label-custom">M&eacute;dico</label>
                    @Html.DropDownList("IdMedico", null, "-- Seleccione un m&eacute;dico --", new { @class = "form-control form-control-custom" })
                    @Html.ValidationMessageFor(model => model.IdMedico, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label-custom">Paciente</label>
                    @Html.DropDownList("IdPaciente", null, "-- Seleccione un paciente --", new { @class = "form-control form-control-custom" })
                    @Html.ValidationMessageFor(model => model.IdPaciente, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label-custom">Fecha de Consulta</label>
                    @Html.EditorFor(model => model.FechaConsulta, new { htmlAttributes = new { @class = "form-control form-control-custom", type = "date" } })
                    @Html.ValidationMessageFor(model => model.FechaConsulta, "", new { @class = "text-danger small" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label-custom">Hora Inicio</label>
                        @Html.EditorFor(model => model.HI, new { htmlAttributes = new { @class = "form-control form-control-custom" } })
                        @Html.ValidationMessageFor(model => model.HI, "", new { @class = "text-danger small" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label-custom">Hora Fin</label>
                        @Html.EditorFor(model => model.HF, new { htmlAttributes = new { @class = "form-control form-control-custom" } })
                        @Html.ValidationMessageFor(model => model.HF, "", new { @class = "text-danger small" })
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label-custom">Diagn&oacute;stico</label>
                    @Html.EditorFor(model => model.Diagnostico, new { htmlAttributes = new { @class = "form-control form-control-custom" } })
                    @Html.ValidationMessageFor(model => model.Diagnostico, "", new { @class = "text-danger small" })
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-guardar">
                        <i class="bi bi-check-circle-fill me-1"></i>Guardar
                    </button>
                    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
                </div>

            </div>
        </div>
    }

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
