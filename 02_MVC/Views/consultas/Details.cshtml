@model _02_MVC.Models.consultas

@{
    ViewBag.Title = "Detalle Consulta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .det-card { border: none; border-radius: 18px; box-shadow: 0 6px 28px rgba(0,0,0,.08); overflow: hidden; max-width: 680px; margin: 0 auto; }
    .det-card-header { background: #0b1d3e; color: #fff; padding: 1.4rem 2rem; }
    .det-card-header h4 { margin: 0; font-weight: 700; font-size: 1.15rem; }
    .det-card-body { padding: 2rem; background: #fff; }
    .det-row { display: flex; padding: .65rem 0; border-bottom: 1px solid #f0f0f0; }
    .det-row:last-of-type { border-bottom: none; }
    .det-label { font-weight: 700; color: #0b1d3e; font-size: .88rem; width: 160px; flex-shrink: 0; }
    .det-value { color: #374151; font-size: .92rem; }
</style>

<div class="container my-5">
    <div class="det-card card">
        <div class="det-card-header">
            <h4><i class="bi bi-calendar2-check-fill me-2"></i>Detalle de Consulta</h4>
        </div>
        <div class="det-card-body">

            <div class="det-row">
                <span class="det-label">Fecha</span>
                <span class="det-value">@Model.FechaConsulta.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="det-row">
                <span class="det-label">Hora Inicio</span>
                <span class="det-value">@Model.HI</span>
            </div>
            <div class="det-row">
                <span class="det-label">Hora Fin</span>
                <span class="det-value">@Model.HF</span>
            </div>
            <div class="det-row">
                <span class="det-label">Diagn&oacute;stico</span>
                <span class="det-value">@Model.Diagnostico</span>
            </div>
            <div class="det-row">
                <span class="det-label">Paciente</span>
                <span class="det-value">@Model.pacientes.Nombre</span>
            </div>
            <div class="det-row">
                <span class="det-label">M&eacute;dico</span>
                <span class="det-value">@Model.medicos.Nombre</span>
            </div>

            <div class="d-flex gap-2 mt-4">
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Medico"))
                {
                    @Html.ActionLink("Editar", "Edit", new { id = Model.IdConsulta }, new { @class = "btn btn-primary rounded-pill px-4" })
                }
                @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
            </div>
        </div>
    </div>
</div>
