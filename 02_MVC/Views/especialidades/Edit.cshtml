@model _02_MVC.Models.especialidades

@{
    ViewBag.Title = "Editar Especialidad";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-card { border:none; border-radius:18px; box-shadow:0 6px 28px rgba(0,0,0,.08); overflow:hidden; max-width:620px; margin:0 auto; }
    .form-card-header { background:#0b1d3e; color:#fff; padding:1.4rem 2rem; }
    .form-card-header h4 { margin:0; font-weight:700; font-size:1.15rem; }
    .form-card-body { padding:2rem; background:#fff; }
    .form-label-custom { font-weight:600; color:#0b1d3e; font-size:.88rem; margin-bottom:.3rem; }
    .form-control-custom { border-radius:10px; border:1px solid #cbd5e1; padding:.65rem 1rem; font-size:.9rem; }
    .form-control-custom:focus { border-color:#0d6efd; box-shadow:0 0 0 .2rem rgba(13,110,253,.15); }
    .btn-guardar { background:#0d6efd; color:#fff; border:none; border-radius:50px; padding:.6rem 2rem; font-weight:700; transition:all .2s ease; }
    .btn-guardar:hover { background:#0b5ed7; transform:translateY(-1px); box-shadow:0 6px 16px rgba(13,110,253,.3); }
</style>

<div class="container my-5">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="form-card card">
            <div class="form-card-header">
                <h4><i class="bi bi-pencil-square me-2"></i>Editar Especialidad</h4>
            </div>
            <div class="form-card-body">
                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
                @Html.HiddenFor(model => model.IdEspecialidad)

                <div class="mb-3">
                    <label class="form-label-custom">Descripci&oacute;n</label>
                    @Html.EditorFor(model => model.Descripcion, new { htmlAttributes = new { @class = "form-control form-control-custom" } })
                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger small" })
                </div>

                @{ var diasActuales = Model.Dias ?? ""; }

                <!-- Días de Atención -->
                <div class="mb-3">
                    <label class="form-label-custom">D&iacute;as de Atenci&oacute;n</label>
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="row g-2">
                                <div class="col-6 col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="dias_L" name="Dias" value="L" @(diasActuales.Contains("L") ? "checked" : "")>
                                        <label class="form-check-label" for="dias_L">Lunes</label>
                                    </div>
                                </div>
                                <div class="col-6 col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="dias_M" name="Dias" value="M" @(diasActuales.Contains("M") ? "checked" : "")>
                                        <label class="form-check-label" for="dias_M">Martes</label>
                                    </div>
                                </div>
                                <div class="col-6 col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="dias_X" name="Dias" value="X" @(diasActuales.Contains("X") ? "checked" : "")>
                                        <label class="form-check-label" for="dias_X">Mi&eacute;rcoles</label>
                                    </div>
                                </div>
                                <div class="col-6 col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="dias_J" name="Dias" value="J" @(diasActuales.Contains("J") ? "checked" : "")>
                                        <label class="form-check-label" for="dias_J">Jueves</label>
                                    </div>
                                </div>
                                <div class="col-6 col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="dias_V" name="Dias" value="V" @(diasActuales.Contains("V") ? "checked" : "")>
                                        <label class="form-check-label" for="dias_V">Viernes</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3 d-flex gap-2">
                                <button type="button" class="btn btn-outline-primary btn-sm" id="btnDiasLV">Lunes a Viernes</button>
                                <button type="button" class="btn btn-outline-danger btn-sm" id="btnDiasClear">Limpiar</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Franja horaria -->
                <div class="mb-3">
                    <label class="form-label-custom" for="Franja_HI">Hora Inicio</label>
                    <input class="form-control form-control-custom" id="Franja_HI" name="Franja_HI" type="time"
                           value="@Model.Franja_HI.ToString(@"hh\:mm")" />
                </div>
                <div class="mb-4">
                    <label class="form-label-custom" for="Franja_HF">Hora Fin</label>
                    <input class="form-control form-control-custom" id="Franja_HF" name="Franja_HF" type="time"
                           value="@Model.Franja_HF.ToString(@"hh\:mm")" />
                </div>

                <div id="alertaHorario" class="alert alert-danger d-none" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i><span id="alertaHorarioMsg"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" id="btnGuardar" class="btn btn-guardar"><i class="bi bi-check-circle-fill me-1"></i>Guardar</button>
                    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            document.getElementById('btnGuardar').addEventListener('click', function (e) {
                var hi = document.getElementById('Franja_HI').value;
                var hf = document.getElementById('Franja_HF').value;
                var alerta = document.getElementById('alertaHorario');
                var msg = document.getElementById('alertaHorarioMsg');

                function toMin(t) { var p = t.split(':'); return parseInt(p[0]) * 60 + parseInt(p[1]); }

                var minVal = 8 * 60, maxVal = 18 * 60;
                var error = null;

                if (!hi || !hf) {
                    error = 'Debe ingresar la hora de inicio y hora de fin.';
                } else if (toMin(hi) < minVal || toMin(hi) > maxVal) {
                    error = 'La hora de inicio debe estar entre 08:00 y 18:00 (Matutina: 08:00 a 12:00 / Vespertina: 12:00 a 18:00).';
                } else if (toMin(hf) < minVal || toMin(hf) > maxVal) {
                    error = 'La hora de fin debe estar entre 08:00 y 18:00 (Matutina: 08:00 a 12:00 / Vespertina: 12:00 a 18:00).';
                } else if (toMin(hi) >= toMin(hf)) {
                    error = 'La hora de inicio debe ser menor a la hora de fin.';
                }

                if (error) {
                    e.preventDefault();
                    msg.textContent = error;
                    alerta.classList.remove('d-none');
                    alerta.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else {
                    alerta.classList.add('d-none');
                }
            });

            var btnLV = document.getElementById('btnDiasLV');
            var btnClr = document.getElementById('btnDiasClear');
            function setDias(codes) {
                var set = {};
                (codes || []).forEach(function (c) { set[c] = true; });
                document.querySelectorAll('input[name="Dias"]').forEach(function (el) {
                    el.checked = !!set[el.value];
                });
            }
            if (btnLV) btnLV.addEventListener('click', function () { setDias(['L', 'M', 'X', 'J', 'V']); });
            if (btnClr) btnClr.addEventListener('click', function () { setDias([]); });
        });
    </script>
}
