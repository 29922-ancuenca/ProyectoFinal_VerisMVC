@model _02_MVC.Models.especialidades

@{
    ViewBag.Title = "Nueva Especialidad";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-card { border:none; border-radius:18px; box-shadow:0 6px 28px rgba(0,0,0,.08); overflow:hidden; max-width:620px; margin:0 auto; }
    .form-card-header { background:#0b1d3e; color:#fff; padding:1.4rem 2rem; }
    .form-card-header h4 { margin:0; font-weight:700; font-size:1.15rem; }
    .form-card-body { padding:2rem; background:#fff; }
    .form-label-custom { font-weight:600; color:#0b1d3e; font-size:.88rem; margin-bottom:.3rem; }
    .form-control-custom { border-radius:10px; border:1px solid #cbd5e1; padding:.65rem 1rem; font-size:.9rem; }
    .form-control-custom:focus { border-color:#0d6efd; box-shadow:0 0 0 .2rem rgba(13,110,253,.15); }
    .btn-guardar { background:#0d6efd; color:#fff; border:none; border-radius:50px; padding:.6rem 2rem; font-weight:700; transition:all .2s ease; }
    .btn-guardar:hover { background:#0b5ed7; transform:translateY(-1px); box-shadow:0 6px 16px rgba(13,110,253,.3); }
</style>

<div class="container my-5">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="form-card card">
            <div class="form-card-header">
                <h4><i class="bi bi-award-fill me-2"></i>Nueva Especialidad</h4>
            </div>
            <div class="form-card-body">
                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <div class="mb-3">
                    <label class="form-label-custom">Descripci&oacute;n</label>
                    @Html.EditorFor(model => model.Descripcion, new { htmlAttributes = new { @class = "form-control form-control-custom", placeholder = "Ej: Cardiologia, Pediatria..." } })
                    @Html.ValidationMessageFor(model => model.Descripcion, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="form-label-custom">D&iacute;as</label>
                    @Html.EditorFor(model => model.Dias, new { htmlAttributes = new { @class = "form-control form-control-custom", placeholder = "Ej: LMX, MJV..." } })
                    @Html.ValidationMessageFor(model => model.Dias, "", new { @class = "text-danger small" })
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label-custom">Hora Inicio</label>
                        @Html.EditorFor(model => model.Franja_HI, new { htmlAttributes = new { @class = "form-control form-control-custom", placeholder = "08:00:00" } })
                        @Html.ValidationMessageFor(model => model.Franja_HI, "", new { @class = "text-danger small" })
                    </div>
                    <div class="col-md-6 mb-4">
                        <label class="form-label-custom">Hora Fin</label>
                        @Html.EditorFor(model => model.Franja_HF, new { htmlAttributes = new { @class = "form-control form-control-custom", placeholder = "18:00:00" } })
                        @Html.ValidationMessageFor(model => model.Franja_HF, "", new { @class = "text-danger small" })
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-guardar"><i class="bi bi-check-circle-fill me-1"></i>Guardar</button>
                    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
