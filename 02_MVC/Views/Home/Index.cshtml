@{
    ViewBag.Title = "Proyecto VERIS";
}

<style>

    .carousel-bg {
        height: 420px;
        position: relative;
        overflow: hidden;
        border-radius: 18px;
    }

        .carousel-bg img,
        #specialtyCarousel .carousel-item > img {
            height: 420px;
            width: 100%;
            object-fit: cover;
            filter: brightness(.55);
        }

    #specialtyCarousel {
        border-radius: 18px;
        overflow: hidden;
    }

        #specialtyCarousel .carousel-caption {
            background: rgba(11, 29, 62, .55);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255,255,255,.22);
            border-radius: 18px;
            padding: 1.5rem 2rem;
            bottom: 4rem;
        }

            #specialtyCarousel .carousel-caption h3 {
                font-size: 2.2rem;
                font-weight: 800;
                margin-bottom: .5rem;
            }

            #specialtyCarousel .carousel-caption p {
                font-size: 1rem;
                margin-bottom: 0;
                opacity: .9;
            }

        #specialtyCarousel .carousel-indicators button {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        #specialtyCarousel .carousel-control-prev,
        #specialtyCarousel .carousel-control-next {
            width: 8%;
        }

    .bg-c-cardio {
        background: linear-gradient(135deg, #7f0000, #b91c1c);
    }

    .bg-c-pediatria {
        background: linear-gradient(135deg, #0c2461, #1d4ed8);
    }

    .bg-c-derma {
        background: linear-gradient(135deg, #92400e, #d97706);
    }

    .bg-c-gineco {
        background: linear-gradient(135deg, #4c1d95, #7c3aed);
    }

    .bg-c-oftalmo {
        background: linear-gradient(135deg, #064e3b, #059669);
    }

    .bg-c-neumo {
        background: linear-gradient(135deg, #0c3a60, #0284c7);
    }

    .bg-c-trauma {
        background: linear-gradient(135deg, #14532d, #15803d);
    }

    .bg-c-neuro {
        background: linear-gradient(135deg, #2e1065, #7c3aed);
    }

    .carousel-img {
        height: 420px;
        object-fit: cover;
    }

    .info-card {
        background: #fff;
        border-radius: 18px;
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: 0 8px 28px rgba(13, 110, 253, .12);
        border: 1px solid #e2e8f0;
        transition: all .3s ease;
        height: 100%;
    }

        .info-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 40px rgba(13, 110, 253, .20);
        }

    .info-icon {
        width: 70px;
        height: 70px;
        background: #e8f0fe;
        color: #0d6efd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 2rem;
    }

    .info-title {
        font-weight: 800;
        color: #0b1d3e;
        margin-bottom: .5rem;
        font-size: 1.1rem;
    }

    .info-text {
        color: #64748b;
        font-size: .9rem;
        line-height: 1.6;
    }

    .hero-wrap {
        background: linear-gradient(135deg, #0b1d3e, #1d4ed8);
        border-radius: 25px;
        padding: 4rem 2rem;
        color: #fff;
    }

    .hero-card {
        max-width: 750px;
        margin: 0 auto;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.25);
        border-radius: 22px;
        padding: 2.5rem;
        backdrop-filter: blur(6px);
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,.18);
        padding: .45rem 1.2rem;
        border-radius: 50px;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .hero-title {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 1rem;
    }

    .hero-sub {
        font-size: 1rem;
        line-height: 1.7;
        opacity: .9;
    }

    .stats {
        background: #f8fbff;
        border-radius: 22px;
        padding: 3rem 1rem;
    }

    .stat-icon {
        font-size: 2.5rem;
        color: #0d6efd;
        margin-bottom: .5rem;
    }

    .stat-num {
        font-size: 2rem;
        font-weight: 800;
        color: #0b1d3e;
    }

    .stat-title {
        color: #64748b;
        font-weight: 600;
    }

    .team-section {
        background: linear-gradient(180deg, #f8fbff, #e8f0fe);
        border-radius: 20px;
    }

    .team-card {
        background: #fff;
        border-radius: 20px;
        padding: 2.5rem 2rem;
        text-align: center;
        box-shadow: 0 8px 30px rgba(13, 110, 253, .12);
        border: 1px solid #e2e8f0;
        transition: all .3s ease;
        height: 100%;
    }

        .team-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 40px rgba(13, 110, 253, .20);
        }

    .team-photo,
    .team-placeholder {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        margin: 0 auto 1.3rem;
        object-fit: cover;
        border: 4px solid #fff;
        outline: 3px solid #0d6efd;
        box-shadow: 0 8px 24px rgba(13, 110, 253, .25);
    }

    .team-placeholder {
        background: linear-gradient(135deg, #0d6efd, #60a5fa);
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 3rem;
    }

    .team-name {
        font-weight: 800;
        color: #0b1d3e;
        margin-bottom: .3rem;
    }

    .team-role {
        color: #0d6efd;
        font-weight: 600;
        margin-bottom: .5rem;
    }

    .team-tech {
        color: #64748b;
        font-size: .85rem;
        margin-bottom: 1.3rem;
    }
</style>

<main class="container text-center mt-5">

    <h1 class="text-primary">Bienvenido a Proyecto Veris</h1>
    <p class="text-muted">Sistema de gesti&oacute;n m&eacute;dica integral.</p>

    <!-- CARRUSEL -->
    <section class="container mt-5">
        <div id="specialtyCarousel" class="carousel slide shadow-sm rounded" data-bs-ride="carousel" data-bs-interval="4000">

            <div class="carousel-indicators">
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="2"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="3"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="4"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="5"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="6"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="7"></button>
            </div>

            <div class="carousel-inner">

                <!-- CARDIOLOGÍA -->
                <div class="carousel-item active">
                    <div class="carousel-bg bg-c-cardio position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1628348068343-c6a848d2b6dd?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Cardiolog&iacute;a</h3>
                            <p>Tratamiento de enfermedades del coraz&oacute;n</p>
                        </div>
                    </div>
                </div>

                <!-- PEDIATRÍA -->
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=1280&q=80"
                         class="d-block w-100"
                         style="height:420px; object-fit:cover;">
                    <div class="carousel-caption">
                        <h3>Pediatr&iacute;a</h3>
                        <p>Atenci&oacute;n m&eacute;dica para ni&ntilde;os</p>
                    </div>
                </div>

                <!-- DERMATOLOGÍA -->
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=1280&q=80"
                         class="d-block w-100"
                         style="height:420px; object-fit:cover;">
                    <div class="carousel-caption">
                        <h3>Dermatolog&iacute;a</h3>
                        <p>Cuidado de la piel</p>
                    </div>
                </div>

                <!-- GINECOLOGÍA -->
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1579154341098-e4e158cc7f55?w=1280&q=80"
                         class="d-block w-100"
                         style="height:420px; object-fit:cover;">
                    <div class="carousel-caption">
                        <h3>Ginecolog&iacute;a</h3>
                        <p>Salud de la mujer</p>
                    </div>
                </div>

                <!-- OFTALMOLOGÍA -->
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1583394838336-acd977736f90?w=1280&q=80"
                         class="d-block w-100"
                         style="height:420px; object-fit:cover;">
                    <div class="carousel-caption">
                        <h3>Oftalmolog&iacute;a</h3>
                        <p>Salud visual</p>
                    </div>
                </div>

                <!-- NEUMOLOGÍA -->
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1559825481-12a05cc00344?w=1280&q=80"
                         class="d-block w-100"
                         style="height:420px; object-fit:cover;">
                    <div class="carousel-caption">
                        <h3>Neumolog&iacute;a</h3>
                        <p>Enfermedades respiratorias</p>
                    </div>
                </div>

                <!-- TRAUMATOLOGÍA -->
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1280&q=80"
                         class="d-block w-100"
                         style="height:420px; object-fit:cover;">
                    <div class="carousel-caption">
                        <h3>Traumatolog&iacute;a</h3>
                        <p>Lesiones y huesos</p>
                    </div>
                </div>

                <!-- NEUROLOGÍA -->
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=1280&q=80"
                         class="d-block w-100"
                         style="height:420px; object-fit:cover;">
                    <div class="carousel-caption">
                        <h3>Neurolog&iacute;a</h3>
                        <p>Sistema nervioso</p>
                    </div>
                </div>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#specialtyCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#specialtyCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>
    </section>
    <!-- MÓDULOS -->
    <section class="mt-5">
        <div class="row g-4">

            <div class="col-md-4">
                <a href="@Url.Action("Index", "paciente")" class="text-decoration-none">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="info-title">M&oacute;dulo Paciente</div>
                        <div class="info-text">
                            Gestionar informaci&oacute;n de pacientes registrados en el sistema.
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="@Url.Action("Index", "medico")" class="text-decoration-none">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>
                        <div class="info-title">M&oacute;dulo M&eacute;dico</div>
                        <div class="info-text">
                            Gestionar informaci&oacute;n de m&eacute;dicos, horarios y especialidades.
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-shield-fill-check"></i>
                        </div>
                        <div class="info-title">M&oacute;dulo Administrador</div>
                        <div class="info-text">
                            Acceso a opciones administrativas y configuraci&oacute;n del sistema.
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </section>

    <!-- HERO -->
    <section class="hero-wrap mt-5">
        <div class="container">
            <div class="hero-card">
                <div class="hero-pill">
                    <i class="bi bi-heart-fill"></i> Pediatr&iacute;a
                </div>

                <div class="hero-title">
                    Cuidemos la salud de tus hijos
                </div>

                <div class="hero-sub">
                    Atenci&oacute;n m&eacute;dica integral enfocada en prevenci&oacute;n,
                    crecimiento y bienestar infantil, en un entorno c&aacute;lido
                    y confiable para toda la familia.
                </div>
            </div>

            <div class="row info-row g-4 mt-4">

                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-clipboard2-heart"></i>
                        </div>
                        <div class="info-title">Control del ni&ntilde;o sano</div>
                        <div class="info-text">
                            Seguimiento del crecimiento y desarrollo infantil por etapas.
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-camera-video"></i>
                        </div>
                        <div class="info-title">Telepediatr&iacute;a</div>
                        <div class="info-text">
                            Orientaci&oacute;n m&eacute;dica desde tu hogar de forma segura.
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-shield-plus"></i>
                        </div>
                        <div class="info-title">Vacunas y prevenci&oacute;n</div>
                        <div class="info-text">
                            Protecci&oacute;n y educaci&oacute;n para una infancia saludable.
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- MÉTRICAS -->
    <section class="stats mt-5">
        <div class="container">
            <div class="row text-center g-4">

                <div class="col-md-4">
                    <div class="stat-icon">
                        <i class="bi bi-hospital"></i>
                    </div>
                    <div class="stat-num">+18</div>
                    <div class="stat-title">A&ntilde;os de experiencia</div>
                </div>

                <div class="col-md-4">
                    <div class="stat-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <div class="stat-num">+1&rsquo;000.000</div>
                    <div class="stat-title">Pacientes atendidos</div>
                </div>

                <div class="col-md-4">
                    <div class="stat-icon">
                        <i class="bi bi-person-vcard"></i>
                    </div>
                    <div class="stat-num">+10</div>
                    <div class="stat-title">Especialidades</div>
                </div>

            </div>
        </div>
    </section>

    <!-- EQUIPO DE DESARROLLO -->
    <section id="equipo" class="team-section mt-5 py-5 mb-5">
        <div class="container" style="max-width:900px;">

            <div class="text-center mb-5">
                <h2 class="fw-bold text-primary">Equipo de Desarrollo</h2>
                <p class="text-muted">Integrantes del Grupo 03 &mdash; Proyecto Final Segundo Parcial</p>
                <div style="width:60px; height:4px; background:#0d6efd; margin:0 auto; border-radius:10px;"></div>
            </div>

            <div class="row justify-content-center g-4">

                <div class="col-md-5">
                    <div class="team-card">
                        <img src="@Url.Content("~/Foto/PamelaCarriel.jpeg")"
                             alt="Pamela Carriel"
                             class="team-photo"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />

                        <div class="team-placeholder" style="display:none;">
                            <i class="bi bi-person-fill"></i>
                        </div>

                        <h5 class="team-name">Pamela Carriel</h5>
                        <p class="team-role">
                            <i class="bi bi-code-slash me-1"></i>Desarrolladora Full Stack
                        </p>
                        <p class="team-tech">
                            .NET Framework &bull; ASP.NET MVC &bull; Entity Framework
                        </p>

                        <a href="https://www.facebook.com/pame.carriel"
                           target="_blank"
                           rel="noopener"
                           class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-facebook me-1"></i>Facebook
                        </a>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="team-card">
                        <img src="@Url.Content("~/Foto/yo.png")"
                             alt="Alisson Cuenca"
                             class="team-photo"
                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />

                        <div class="team-placeholder" style="display:none;">
                            <i class="bi bi-person-fill"></i>
                        </div>

                        <h5 class="team-name">Alisson Cuenca</h5>
                        <p class="team-role">
                            <i class="bi bi-code-slash me-1"></i>Desarrolladora Full Stack
                        </p>
                        <p class="team-tech">
                            .NET Framework &bull; ASP.NET MVC &bull; Entity Framework
                        </p>

                        <a href="https://www.facebook.com/USUARIO_FACEBOOK"
                           target="_blank"
                           rel="noopener"
                           class="btn btn-primary rounded-pill px-4">
                            <i class="bi bi-facebook me-1"></i>Facebook
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </section>

</main>