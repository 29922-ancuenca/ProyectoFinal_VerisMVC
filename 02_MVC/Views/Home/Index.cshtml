@{
    ViewBag.Title = "Clinica Pediatrica Veris";
}

<style>

    .carousel-bg {
        height: 420px;
        position: relative;
        overflow: hidden;
        border-radius: 18px;
    }

        .carousel-bg img,
        #specialtyCarousel .carousel-item > img {
            height: 420px;
            width: 100%;
            object-fit: cover;
            filter: brightness(.55);
        }

    #specialtyCarousel {
        border-radius: 18px;
        overflow: hidden;
    }

        #specialtyCarousel .carousel-caption {
            background: rgba(11, 29, 62, .55);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(255,255,255,.22);
            border-radius: 18px;
            padding: 1.5rem 2rem;
            bottom: 4rem;
        }

            #specialtyCarousel .carousel-caption h3 {
                font-size: 2.2rem;
                font-weight: 800;
                margin-bottom: .5rem;
            }

            #specialtyCarousel .carousel-caption p {
                font-size: 1rem;
                margin-bottom: 0;
                opacity: .9;
            }

        #specialtyCarousel .carousel-indicators button {
            width: 10px;
            height: 10px;
            border-radius: 50%;
        }

        #specialtyCarousel .carousel-control-prev,
        #specialtyCarousel .carousel-control-next {
            width: 8%;
        }

    /* Gradientes pediátricos */
    .bg-c-pedi-general { background: linear-gradient(135deg, #0c4a6e, #0284c7); }
    .bg-c-neonato      { background: linear-gradient(135deg, #831843, #db2777); }
    .bg-c-cardio-pedi  { background: linear-gradient(135deg, #7f0000, #b91c1c); }
    .bg-c-neumo-pedi   { background: linear-gradient(135deg, #0c3a60, #0ea5e9); }
    .bg-c-neuro-pedi   { background: linear-gradient(135deg, #2e1065, #7c3aed); }
    .bg-c-vacunas      { background: linear-gradient(135deg, #064e3b, #059669); }
    .bg-c-nutri        { background: linear-gradient(135deg, #92400e, #d97706); }
    .bg-c-urgencias    { background: linear-gradient(135deg, #7f1d1d, #ef4444); }

    .info-card {
        background: #fff;
        border-radius: 18px;
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: 0 8px 28px rgba(13, 110, 253, .12);
        border: 1px solid #e2e8f0;
        transition: all .3s ease;
        height: 100%;
    }

        .info-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 40px rgba(13, 110, 253, .20);
        }

    .info-icon {
        width: 70px;
        height: 70px;
        background: #e8f0fe;
        color: #0d6efd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 2rem;
    }

    .info-title {
        font-weight: 800;
        color: #0b1d3e;
        margin-bottom: .5rem;
        font-size: 1.1rem;
    }

    .info-text {
        color: #64748b;
        font-size: .9rem;
        line-height: 1.6;
    }

    .hero-wrap {
        background: linear-gradient(135deg, #0b1d3e, #1d4ed8);
        border-radius: 25px;
        padding: 4rem 2rem;
        color: #fff;
    }

    .hero-card {
        max-width: 750px;
        margin: 0 auto;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.25);
        border-radius: 22px;
        padding: 2.5rem;
        backdrop-filter: blur(6px);
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,.18);
        padding: .45rem 1.2rem;
        border-radius: 50px;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .hero-title {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 1rem;
    }

    .hero-sub {
        font-size: 1rem;
        line-height: 1.7;
        opacity: .9;
    }

    .stats {
        background: #f8fbff;
        border-radius: 22px;
        padding: 3rem 1rem;
    }

    .stat-icon {
        font-size: 2.5rem;
        color: #0d6efd;
        margin-bottom: .5rem;
    }

    .stat-num {
        font-size: 2rem;
        font-weight: 800;
        color: #0b1d3e;
    }

    .stat-title {
        color: #64748b;
        font-weight: 600;
    }

    .team-section {
        background: linear-gradient(180deg, #f8fbff, #e8f0fe);
        border-radius: 20px;
    }

    .team-card {
        background: #fff;
        border-radius: 20px;
        padding: 2.5rem 2rem;
        text-align: center;
        box-shadow: 0 8px 30px rgba(13, 110, 253, .12);
        border: 1px solid #e2e8f0;
        transition: all .3s ease;
        height: 100%;
    }

        .team-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 40px rgba(13, 110, 253, .20);
        }

    .team-photo,
    .team-placeholder {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        margin: 0 auto 1.3rem;
        object-fit: cover;
        border: 4px solid #fff;
        outline: 3px solid #0d6efd;
        box-shadow: 0 8px 24px rgba(13, 110, 253, .25);
    }

    .team-placeholder {
        background: linear-gradient(135deg, #0d6efd, #60a5fa);
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 3rem;
    }

    .team-name {
        font-weight: 800;
        color: #0b1d3e;
        margin-bottom: .3rem;
    }

    .team-role {
        color: #0d6efd;
        font-weight: 600;
        margin-bottom: .5rem;
    }

    .team-tech {
        color: #64748b;
        font-size: .85rem;
        margin-bottom: 1.3rem;
    }
</style>

<main class="container text-center mt-5">

    <h1 class="text-primary">Bienvenido a Cl&iacute;nica Pedi&aacute;trica Veris</h1>
    <p class="text-muted">Atenci&oacute;n m&eacute;dica integral para ni&ntilde;os y adolescentes.</p>

    <!-- CARRUSEL -->
    <section class="container mt-5">
        <div id="specialtyCarousel" class="carousel slide shadow-sm rounded" data-bs-ride="carousel" data-bs-interval="4000">

            <div class="carousel-indicators">
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="2"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="3"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="4"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="5"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="6"></button>
                <button type="button" data-bs-target="#specialtyCarousel" data-bs-slide-to="7"></button>
            </div>

            <div class="carousel-inner">

                <!-- PEDIATRÍA GENERAL -->
                <div class="carousel-item active">
                    <div class="carousel-bg bg-c-pedi-general position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1676313027775-a5a3dca6f98b?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Pediatr&iacute;a General</h3>
                            <p>Atenci&oacute;n m&eacute;dica integral del ni&ntilde;o y adolescente</p>
                        </div>
                    </div>
                </div>

                <!-- NEONATOLOGÍA -->
                <div class="carousel-item">
                    <div class="carousel-bg bg-c-neonato position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1604807787527-e7ad386cca6a?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Neonatolog&iacute;a</h3>
                            <p>Cuidado especializado del reci&eacute;n nacido</p>
                        </div>
                    </div>
                </div>

                <!-- CARDIOLOGÍA PEDIÁTRICA -->
                <div class="carousel-item">
                    <div class="carousel-bg bg-c-cardio-pedi position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1632053002928-1919605ee6f7?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Cardiolog&iacute;a Pedi&aacute;trica</h3>
                            <p>Salud cardiovascular desde la infancia</p>
                        </div>
                    </div>
                </div>

                <!-- NEUMOLOGÍA PEDIÁTRICA -->
                <div class="carousel-item">
                    <div class="carousel-bg bg-c-neumo-pedi position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1632052998047-1faea5c31145?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Neumolog&iacute;a Pedi&aacute;trica</h3>
                            <p>Tratamiento de enfermedades respiratorias en ni&ntilde;os</p>
                        </div>
                    </div>
                </div>

                <!-- NEUROLOGÍA PEDIÁTRICA -->
                <div class="carousel-item">
                    <div class="carousel-bg bg-c-neuro-pedi position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1758691463331-2ac00e6f676f?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Neurolog&iacute;a Pedi&aacute;trica</h3>
                            <p>Desarrollo neurol&oacute;gico y salud del sistema nervioso</p>
                        </div>
                    </div>
                </div>

                <!-- VACUNACIÓN -->
                <div class="carousel-item">
                    <div class="carousel-bg bg-c-vacunas position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1576766125535-b04e15fd0273?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Vacunaci&oacute;n e Inmunolog&iacute;a</h3>
                            <p>Esquema completo de vacunas y prevenci&oacute;n de enfermedades</p>
                        </div>
                    </div>
                </div>

                <!-- NUTRICIÓN PEDIÁTRICA -->
                <div class="carousel-item">
                    <div class="carousel-bg bg-c-nutri position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1774188271212-8bad27d24d08?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Nutrici&oacute;n Pedi&aacute;trica</h3>
                            <p>Alimentaci&oacute;n saludable para el crecimiento &oacute;ptimo</p>
                        </div>
                    </div>
                </div>

                <!-- URGENCIAS PEDIÁTRICAS -->
                <div class="carousel-item">
                    <div class="carousel-bg bg-c-urgencias position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1768583235368-ec6bf1ab1974?w=1280&q=80"
                             class="w-100"
                             style="height:420px; object-fit:cover;">
                        <div class="carousel-caption">
                            <h3>Urgencias Pedi&aacute;tricas</h3>
                            <p>Atenci&oacute;n inmediata las 24 horas para tu hijo</p>
                        </div>
                    </div>
                </div>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#specialtyCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#specialtyCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>
    </section>

    <!-- MÓDULOS -->
    <section class="mt-5">
        <div class="row g-4">

            <div class="col-md-4">
                <a href="@Url.Action("Index", "paciente")" class="text-decoration-none">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div class="info-title">M&oacute;dulo Paciente</div>
                        <div class="info-text">
                            Gestiona el historial cl&iacute;nico y la informaci&oacute;n de los peque&ntilde;os pacientes.
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="@Url.Action("Index", "medico")" class="text-decoration-none">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>
                        <div class="info-title">M&oacute;dulo M&eacute;dico</div>
                        <div class="info-text">
                            Administra el equipo de pediatras, horarios y especialidades infantiles.
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="@Url.Action("Index", "Home")" class="text-decoration-none">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-shield-fill-check"></i>
                        </div>
                        <div class="info-title">M&oacute;dulo Administrador</div>
                        <div class="info-text">
                            Acceso a opciones administrativas y configuraci&oacute;n de la cl&iacute;nica.
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </section>

    <!-- HERO -->
    <section class="hero-wrap mt-5">
        <div class="container">
            <div class="hero-card">
                <div class="hero-pill">
                    <i class="bi bi-emoji-smile-fill"></i> Cuidamos a tus hijos
                </div>

                <div class="hero-title">
                    Salud infantil con amor y experiencia
                </div>

                <div class="hero-sub">
                    En Cl&iacute;nica Pedi&aacute;trica Veris brindamos atenci&oacute;n m&eacute;dica especializada
                    desde el nacimiento hasta la adolescencia, en un ambiente c&aacute;lido, seguro
                    y dise&ntilde;ado especialmente para los m&aacute;s peque&ntilde;os de la familia.
                </div>
            </div>

            <div class="row info-row g-4 mt-4">

                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-clipboard2-heart"></i>
                        </div>
                        <div class="info-title">Control del ni&ntilde;o sano</div>
                        <div class="info-text">
                            Seguimiento peri&oacute;dico del crecimiento y desarrollo infantil por etapas.
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-shield-plus"></i>
                        </div>
                        <div class="info-title">Vacunas y prevenci&oacute;n</div>
                        <div class="info-text">
                            Esquema completo de inmunizaci&oacute;n para una infancia protegida y saludable.
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-card">
                        <div class="info-icon">
                            <i class="bi bi-camera-video"></i>
                        </div>
                        <div class="info-title">Telepediatr&iacute;a</div>
                        <div class="info-text">
                            Consultas virtuales con pediatras certificados desde la comodidad de tu hogar.
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- SERVICIOS PEDIÁTRICOS -->
    <section class="mt-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">Nuestros Servicios Pedi&aacute;tricos</h2>
            <p class="text-muted">Atenci&oacute;n especializada para cada etapa del desarrollo infantil</p>
            <div style="width:60px; height:4px; background:#0d6efd; margin:0 auto; border-radius:10px;"></div>
        </div>
        <div class="row g-4">

            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon"><i class="bi bi-heart-fill"></i></div>
                    <div class="info-title">Neonatolog&iacute;a</div>
                    <div class="info-text">
                        Cuidado intensivo y especializado para reci&eacute;n nacidos prematuros o de alto riesgo.
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon"><i class="bi bi-activity"></i></div>
                    <div class="info-title">Urgencias 24/7</div>
                    <div class="info-text">
                        Atenci&oacute;n de emergencias pedi&aacute;tricas las 24 horas del d&iacute;a, los 7 d&iacute;as de la semana.
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon"><i class="bi bi-basket-fill"></i></div>
                    <div class="info-title">Nutrici&oacute;n Infantil</div>
                    <div class="info-text">
                        Planes nutricionales personalizados para el crecimiento y desarrollo &oacute;ptimo del ni&ntilde;o.
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon"><i class="bi bi-lightning-fill"></i></div>
                    <div class="info-title">Neurolog&iacute;a Pedi&aacute;trica</div>
                    <div class="info-text">
                        Diagn&oacute;stico y tratamiento de trastornos del sistema nervioso en la infancia.
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon"><i class="bi bi-wind"></i></div>
                    <div class="info-title">Neumolog&iacute;a Pedi&aacute;trica</div>
                    <div class="info-text">
                        Tratamiento del asma, bronquitis y otras enfermedades respiratorias infantiles.
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-icon"><i class="bi bi-emoji-laughing-fill"></i></div>
                    <div class="info-title">Odontopediatr&iacute;a</div>
                    <div class="info-text">
                        Cuidado dental preventivo y tratamiento bucodental para ni&ntilde;os y adolescentes.
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- MÉTRICAS -->
    <section class="stats mt-5">
        <div class="container">
            <div class="row text-center g-4">

                <div class="col-md-4">
                    <div class="stat-icon">
                        <i class="bi bi-hospital"></i>
                    </div>
                    <div class="stat-num">+15</div>
                    <div class="stat-title">A&ntilde;os de experiencia pedi&aacute;trica</div>
                </div>

                <div class="col-md-4">
                    <div class="stat-icon">
                        <i class="bi bi-people"></i>
                    </div>
                    <div class="stat-num">+50.000</div>
                    <div class="stat-title">Ni&ntilde;os atendidos</div>
                </div>

                <div class="col-md-4">
                    <div class="stat-icon">
                        <i class="bi bi-person-vcard"></i>
                    </div>
                    <div class="stat-num">+8</div>
                    <div class="stat-title">Especialidades pedi&aacute;tricas</div>
                </div>

            </div>
        </div>
    </section>

    <!-- EQUIPO DE DESARROLLO -->
    <section id="equipo" class="team-section mt-5 py-5 mb-5">
        <div class="container" style="max-width:900px;">

            <div class="text-center mb-5">
                <h2 class="fw-bold text-primary">Equipo de Desarrollo</h2>
                <p class="text-muted">Integrantes del Grupo 03 &mdash; Proyecto Final Segundo Parcial</p>
                <div style="width:60px; height:4px; background:#0d6efd; margin:0 auto; border-radius:10px;"></div>
            </div>

            <div class="row justify-content-center g-4">

                <div class="col-md-5">
                    <div class="team-card">
                        <img src="@Url.Content("~/Foto/PamelaCarriel.jpeg")"
