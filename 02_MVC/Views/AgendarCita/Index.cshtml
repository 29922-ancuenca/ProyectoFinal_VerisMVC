@{
    ViewBag.Title = "Agendar Cita";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .agendar-wrap { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem; }
    .agendar-title { text-align:center; color:#0b1d3e; font-weight:800; font-size:1.5rem; margin-bottom:2rem; }
    .panel-card { background:#fff; border-radius:18px; box-shadow:0 4px 24px rgba(0,0,0,.08); padding:1.8rem; height:100%; }
    .step-label { font-weight:700; color:#0b1d3e; font-size:.85rem; margin-bottom:.4rem; display:flex; align-items:center; gap:6px; }
    .step-num { background:#0d6efd; color:#fff; border-radius:50%; width:20px; height:20px; display:inline-flex; align-items:center; justify-content:center; font-size:.72rem; font-weight:700; flex-shrink:0; }
    .form-ctrl { border-radius:10px; border:1.5px solid #cbd5e1; padding:.6rem 1rem; font-size:.9rem; width:100%; margin-bottom:1rem; }
    .form-ctrl:focus { border-color:#0d6efd; outline:none; box-shadow:0 0 0 .15rem rgba(13,110,253,.15); }
    .form-ctrl:disabled { background:#f8fafc; color:#94a3b8; }

    /* Calendar */
    .cal-header { display:flex; align-items:center; justify-content:space-between; background:#0d6efd; color:#fff; border-radius:12px 12px 0 0; padding:.7rem 1.2rem; }
    .cal-header .mes-nombre { font-weight:700; font-size:1rem; }
    .cal-nav { background:none; border:none; color:#fff; font-size:1.2rem; cursor:pointer; padding:0 .5rem; }
    .cal-grid { display:grid; grid-template-columns:repeat(5,1fr); }
    .cal-dow { text-align:center; font-size:.75rem; font-weight:700; color:#64748b; padding:.5rem 0; background:#f8fafc; }
    .cal-day { text-align:center; padding:.5rem .2rem; font-size:.82rem; cursor:default; position:relative; border:1px solid #f1f5f9; min-height:52px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px; }
    .cal-day.disponible { background:#f0fdf4; cursor:pointer; }
    .cal-day.disponible:hover { background:#dcfce7; }
    .cal-day.seleccionado { background:#fbbf24 !important; font-weight:700; }
    .cal-day.no-disponible { color:#cbd5e1; }
    .cal-day.otro-mes { color:#e2e8f0; background:#fafafa; }
    .slot-count { font-size:.68rem; color:#16a34a; font-weight:600; display:flex; align-items:center; gap:2px; }
    .slot-count .dot { width:7px; height:7px; background:#16a34a; border-radius:50%; display:inline-block; }
    .cal-day.seleccionado .slot-count { color:#92400e; }
    .cal-day.seleccionado .slot-count .dot { background:#92400e; }
    .cal-legend { display:flex; gap:1rem; font-size:.75rem; margin-top:.5rem; }
    .leg-dot { width:12px; height:12px; border-radius:3px; display:inline-block; }

    /* Hours grid */
    .horas-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:.5rem; margin-top:.5rem; }
    .hora-btn { border:1.5px solid #cbd5e1; background:#fff; border-radius:10px; padding:.5rem; font-size:.82rem; font-weight:600; cursor:pointer; transition:all .15s; text-align:center; }
    .hora-btn:hover { border-color:#0d6efd; background:#eff6ff; }
    .hora-btn.seleccionada { background:#0d6efd; color:#fff; border-color:#0d6efd; }

    /* Confirm */
    .btn-confirmar { background:#0d6efd; color:#fff; border:none; border-radius:50px; padding:.65rem 2rem; font-weight:700; width:100%; margin-top:1rem; font-size:.95rem; transition:all .2s; }
    .btn-confirmar:hover:not(:disabled) { background:#0b5ed7; transform:translateY(-1px); box-shadow:0 6px 16px rgba(13,110,253,.3); }
    .btn-confirmar:disabled { background:#94a3b8; cursor:not-allowed; }

    /* Alert */
    .alert-box { border-radius:10px; padding:.8rem 1rem; font-size:.88rem; margin-top:1rem; display:none; }
    .alert-box.error { background:#fef2f2; color:#b91c1c; border:1px solid #fecaca; }
    .alert-box.success { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
</style>

<div class="agendar-wrap">
    <h3 class="agendar-title"><i class="bi bi-calendar-plus-fill me-2" style="color:#0d6efd;"></i>Agendar Cita M&eacute;dica</h3>

    <div class="row g-4">

        <!-- Panel izquierdo -->
        <div class="col-lg-5">
            <div class="panel-card">

                <p class="step-label"><span class="step-num">1</span> Especialidad y M&eacute;dico</p>

                @if (ViewBag.EsAdmin == true)
                {
                    <label style="font-size:.8rem;color:#64748b;">Paciente</label>
                    <select id="ddlPaciente" class="form-ctrl">
                        <option value="">-- Seleccione un paciente --</option>
                        @foreach (SelectListItem p in ViewBag.Pacientes)
                        {
                            <option value="@p.Value">@p.Text</option>
                        }
                    </select>
                }

                <label style="font-size:.8rem;color:#64748b;">Especialidad</label>
                <select id="ddlEspecialidad" class="form-ctrl">
                    <option value="">-- Seleccione --</option>
                    @foreach (SelectListItem esp in ViewBag.Especialidades)
                    {
                        <option value="@esp.Value">@esp.Text</option>
                    }
                </select>

                <label style="font-size:.8rem;color:#64748b;">M&eacute;dico</label>
                <select id="ddlMedico" class="form-ctrl" disabled>
                    <option value="">-- Primero seleccione especialidad --</option>
                </select>

                <hr style="margin:1rem 0;">

                <p class="step-label" id="labelHoras" style="display:none;"><span class="step-num">3</span> Horarios Disponibles</p>
                <div id="horasContainer" style="display:none;">
                    <p id="fechaSelLabel" style="font-size:.8rem;color:#64748b;margin-bottom:.5rem;"></p>
                    <div class="horas-grid" id="horasGrid"></div>
                </div>

                <div id="alertBox" class="alert-box"></div>

                <button id="btnConfirmar" class="btn-confirmar" disabled>
                    <i class="bi bi-check-circle-fill me-1"></i>Confirmar Cita
                </button>

            </div>
        </div>

        <!-- Panel derecho: calendario -->
        <div class="col-lg-7">
            <div class="panel-card">
                <p class="step-label"><span class="step-num">2</span> Selecciona Fecha</p>

                <div id="calWrapper" style="display:none;">
                    <div class="cal-header">
                        <button class="cal-nav" id="btnPrev">&#8249;</button>
                        <span class="mes-nombre" id="calTitulo"></span>
                        <button class="cal-nav" id="btnNext">&#8250;</button>
                    </div>
                    <div class="cal-grid" id="calDow"></div>
                    <div class="cal-grid" id="calBody"></div>
                    <div class="cal-legend">
                        <span><span class="leg-dot" style="background:#dcfce7;border:1px solid #86efac;"></span> Disponible</span>
                        <span><span class="leg-dot" style="background:#fbbf24;"></span> Seleccionado</span>
                        <span><span class="leg-dot" style="background:#f1f5f9;border:1px solid #e2e8f0;"></span> No disponible</span>
                    </div>
                </div>

                <div id="calPlaceholder" style="text-align:center;padding:3rem 1rem;color:#94a3b8;">
                    <i class="bi bi-calendar3" style="font-size:3rem;"></i>
                    <p style="margin-top:.8rem;font-size:.9rem;">Selecciona una especialidad y un m&eacute;dico para ver el calendario</p>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jquery")
    <script>
        var ANIO_MIN = 2000;
        var ANIO_MAX = 2030;

        // Semana ISO 8601 (calendario gregoriano)
        // La semana 1 contiene el primer jueves del año
        function isoSemana(fecha) {
            var d = new Date(Date.UTC(fecha.getFullYear(), fecha.getMonth(), fecha.getDate()));
            var dow = d.getUTCDay() || 7; // domingo = 7
            d.setUTCDate(d.getUTCDate() + 4 - dow);
            var anioISO = d.getUTCFullYear();
            var inicioAnio = new Date(Date.UTC(anioISO, 0, 1));
            var semana = Math.ceil(((d - inicioAnio) / 86400000 + 1) / 7);
            return { semana: semana, anio: anioISO };
        }

        // Cuántas semanas ISO tiene un año (52 o 53)
        function semanasEnAnio(y) {
            function p(n) { return n + Math.floor(n / 4) - Math.floor(n / 100) + Math.floor(n / 400); }
            return (p(y) % 7 === 4 || p(y - 1) % 7 === 3) ? 53 : 52;
        }

        var hoy    = new Date();
        var sw     = isoSemana(hoy);
        var calAnio   = sw.anio;
        var calSemana = sw.semana;

        var diasDisponibles  = [];
        var slotsLibres      = {};
        var selectedFecha    = null;
        var selectedHora     = null;
        var selectedIdMedico = null;
        var lunesSemana      = null;

        var dows     = ['Lu', 'Ma', 'Mi', 'Ju', 'Vi'];
        var diasNomb = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
        var mesesC   = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
        var mesesN   = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

        // --- Especialidad cambia ---
        $('#ddlEspecialidad').on('change', function () {
            var idEsp = $(this).val();
            resetAll();
            if (!idEsp) { $('#ddlMedico').prop('disabled', true).html('<option value="">-- Primero seleccione especialidad --</option>'); return; }
            $.getJSON('@Url.Action("GetMedicos","AgendarCita")', { idEspecialidad: idEsp }, function (data) {
                var ddl = $('#ddlMedico').empty().append('<option value="">-- Seleccione un médico --</option>');
                $.each(data, function (i, m) { ddl.append($('<option>', { value: m.id, text: m.nombre })); });
                ddl.prop('disabled', false);
            });
        });

        // --- Médico cambia ---
        $('#ddlMedico').on('change', function () {
            selectedIdMedico = $(this).val();
            resetFechaHora();
            if (!selectedIdMedico) { $('#calWrapper').hide(); $('#calPlaceholder').show(); return; }
            $('#calPlaceholder').hide();
            $('#calWrapper').show();
            cargarCalendario();
        });

        // --- Navegación semana (ISO 8601 gregoriano) ---
        $('#btnPrev').on('click', function () {
            calSemana--;
            if (calSemana < 1) {
                calAnio--;
                calSemana = semanasEnAnio(calAnio);
            }
            if (calAnio < ANIO_MIN) { calAnio = ANIO_MIN; calSemana = 1; }
            resetFechaHora();
            cargarCalendario();
        });

        $('#btnNext').on('click', function () {
            calSemana++;
            if (calSemana > semanasEnAnio(calAnio)) { calSemana = 1; calAnio++; }
            if (calAnio > ANIO_MAX) { calAnio = ANIO_MAX; calSemana = semanasEnAnio(calAnio); }
            resetFechaHora();
            cargarCalendario();
        });

        // --- Cargar calendario ---
        function cargarCalendario() {
            actualizarBotonesNav();
            $.getJSON('@Url.Action("GetCalendario","AgendarCita")', {
                idMedico: selectedIdMedico, anio: calAnio, semana: calSemana
            }, function (data) {
                diasDisponibles = data.diasDisponibles || [];
                slotsLibres     = data.slotsLibres     || {};
                lunesSemana     = data.lunesSemana;
                renderCalendario(data.lunesSemana, data.viernesSemana);
            });
        }

        function actualizarBotonesNav() {
            $('#btnPrev').prop('disabled', calAnio === ANIO_MIN && calSemana === 1);
            $('#btnNext').prop('disabled', calAnio === ANIO_MAX && calSemana === semanasEnAnio(ANIO_MAX));
        }

        function renderCalendario(lunesStr, viernesStr) {
            var lunes   = parseFecha(lunesStr);
            var viernes = parseFecha(viernesStr);

            // Título: "Semana 20 — 12 may al 16 may 2025"
            var titulo = 'Semana ' + calSemana + ' &mdash; '
                + lunes.getDate() + ' ' + mesesC[lunes.getMonth()]
                + ' al '
                + viernes.getDate() + ' ' + mesesC[viernes.getMonth()]
                + ' ' + calAnio;
            $('#calTitulo').html(titulo);

            // Cabecera días
            var dowHtml = '';
            dows.forEach(function (d) { dowHtml += '<div class="cal-dow">' + d + '</div>'; });
            $('#calDow').html(dowHtml);

            var hoyD = new Date(); hoyD.setHours(0, 0, 0, 0);
            var html = '';

            for (var i = 0; i <= 4; i++) {
                var fecha     = new Date(lunes.getFullYear(), lunes.getMonth(), lunes.getDate() + i);
                var fechaStr  = fecha.getFullYear() + '-' + pad(fecha.getMonth() + 1) + '-' + pad(fecha.getDate());
                var esPasado  = fecha < hoyD;
                var esDisp    = diasDisponibles.indexOf(fechaStr) >= 0;
                var esSel     = fechaStr === selectedFecha;
                var slots     = slotsLibres[fechaStr] || 0;
                var clickable = esDisp && slots > 0 && !esPasado;
                var cls       = esSel ? 'seleccionado' : (clickable ? 'disponible' : 'no-disponible');

                html += '<div class="cal-day ' + cls + '" ' + (clickable ? 'data-fecha="' + fechaStr + '"' : '') + '>';
                html += '<span style="font-size:.7rem;color:#94a3b8;">' + diasNomb[(fecha.getDay())] + '</span>';
                html += '<span>' + fecha.getDate() + ' ' + mesesC[fecha.getMonth()] + '</span>';
                if (clickable) html += '<span class="slot-count">' + slots + '<span class="dot"></span></span>';
                html += '</div>';
            }
            $('#calBody').html(html);

            $('#calBody').off('click', '.disponible').on('click', '.disponible', function () {
                selectedFecha = $(this).data('fecha');
                selectedHora  = null;
                $('#btnConfirmar').prop('disabled', true);
                renderCalendario(lunesStr, viernesStr);
                cargarHoras();
            });
        }

        // --- Horas ---
        function cargarHoras() {
            $('#horasContainer').show();
            $('#labelHoras').show();
            var partes = selectedFecha.split('-');
            var d = new Date(parseInt(partes[0]), parseInt(partes[1]) - 1, parseInt(partes[2]));
            $('#fechaSelLabel').text(diasNomb[d.getDay()] + ' ' + d.getDate() + ' de ' + mesesC[d.getMonth()]);
            $('#horasGrid').html('<span style="color:#94a3b8;font-size:.85rem;">Cargando...</span>');

            $.getJSON('@Url.Action("GetHoras","AgendarCita")', {
                idMedico: selectedIdMedico, fecha: selectedFecha
            }, function (horas) {
                if (horas.length === 0) {
                    $('#horasGrid').html('<span style="color:#ef4444;font-size:.85rem;">No hay horas disponibles para este día.</span>');
                    return;
                }
                var html = '';
                horas.forEach(function (h) {
                    var sel = h === selectedHora ? 'seleccionada' : '';
                    html += '<button type="button" class="hora-btn ' + sel + '" data-hora="' + h + '"><i class="bi bi-clock me-1"></i>' + h + '</button>';
                });
                $('#horasGrid').html(html);
                $('#horasGrid').off('click', '.hora-btn').on('click', '.hora-btn', function () {
                    selectedHora = $(this).data('hora');
                    $('.hora-btn').removeClass('seleccionada');
                    $(this).addClass('seleccionada');
                    $('#btnConfirmar').prop('disabled', false);
                    showAlert('', '');
                });
            });
        }

        // --- Confirmar ---
        $('#btnConfirmar').on('click', function () {
            if (!selectedFecha || !selectedHora || !selectedIdMedico) return;

            var idPaciente = $('#ddlPaciente').length ? $('#ddlPaciente').val() : null;
            if ($('#ddlPaciente').length && !idPaciente) {
                showAlert('Debe seleccionar un paciente.', 'error');
                return;
            }

            $(this).prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i>Agendando...');
            $.post('@Url.Action("Confirmar","AgendarCita")', {
                idMedico:   selectedIdMedico,
                fecha:      selectedFecha,
                hora:       selectedHora,
                idPaciente: idPaciente
            }, function (resp) {
                if (resp.success) {
                    showAlert(resp.message, 'success');
                    cargarCalendario();
                    cargarHoras();
                    selectedHora = null;
                    $('#btnConfirmar').prop('disabled', true).html('<i class="bi bi-check-circle-fill me-1"></i>Confirmar Cita');
                } else {
                    showAlert(resp.message, 'error');
                    $('#btnConfirmar').prop('disabled', false).html('<i class="bi bi-check-circle-fill me-1"></i>Confirmar Cita');
                }
            });
        });

        // --- Helpers ---
        function parseFecha(str) {
            var p = str.split('-');
            return new Date(parseInt(p[0]), parseInt(p[1]) - 1, parseInt(p[2]));
        }

        function resetAll() {
            resetFechaHora();
            selectedIdMedico = null;
            $('#calWrapper').hide();
            $('#calPlaceholder').show();
        }

        function resetFechaHora() {
            selectedFecha = null;
            selectedHora  = null;
            $('#horasContainer').hide();
            $('#labelHoras').hide();
            $('#btnConfirmar').prop('disabled', true);
            showAlert('', '');
        }

        function showAlert(msg, tipo) {
            var box = $('#alertBox');
            if (!msg) { box.hide(); return; }
            box.removeClass('error success').addClass(tipo).text(msg).show();
        }

        function pad(n) { return n < 10 ? '0' + n : '' + n; }
    </script>
}


