@model _02_MVC.Models.pacientes

@{
    ViewBag.Title = "Detalle Paciente";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .det-card { border: none; border-radius: 18px; box-shadow: 0 6px 28px rgba(0,0,0,.08); overflow: hidden; max-width: 680px; margin: 0 auto; }
    .det-card-header { background: #0b1d3e; color: #fff; padding: 1.4rem 2rem; }
    .det-card-header h4 { margin: 0; font-weight: 700; font-size: 1.15rem; }
    .det-card-body { padding: 2rem; background: #fff; }
    .det-row { display: flex; padding: .65rem 0; border-bottom: 1px solid #f0f0f0; }
    .det-row:last-of-type { border-bottom: none; }
    .det-label { font-weight: 700; color: #0b1d3e; font-size: .88rem; width: 160px; flex-shrink: 0; }
    .det-value { color: #374151; font-size: .92rem; }
</style>

<div class="container my-5">
    <div class="det-card card">
        <div class="det-card-header">
            <h4><i class="bi bi-person-circle me-2"></i>Detalle del Paciente</h4>
        </div>
        <div class="det-card-body">

            @if (!string.IsNullOrEmpty(Model.Foto))
            {
                <div class="text-center mb-4">
                    <img src='/im%C3%A1genes/usuarios/@Model.Foto'
                         style="width:90px; height:90px; object-fit:cover; border-radius:50%; border:3px solid #e2e8f0;" alt="foto" />
                </div>
            }

            <div class="det-row">
                <span class="det-label">Nombre</span>
                <span class="det-value">@Model.Nombre</span>
            </div>
            <div class="det-row">
                <span class="det-label">C&eacute;dula</span>
                <span class="det-value">@Model.Cedula</span>
            </div>
            <div class="det-row">
                <span class="det-label">Edad</span>
                <span class="det-value">@Model.Edad a&ntilde;os</span>
            </div>
            <div class="det-row">
                <span class="det-label">G&eacute;nero</span>
                <span class="det-value">@Model.Genero</span>
            </div>
            <div class="det-row">
                <span class="det-label">Estatura</span>
                <span class="det-value">@Model.Estatura m</span>
            </div>
            <div class="det-row">
                <span class="det-label">Peso</span>
                <span class="det-value">@Model.Peso kg</span>
            </div>
            <div class="det-row">
                <span class="det-label">Email</span>
                <span class="det-value">@Model.AspNetUsers.Email</span>
            </div>

            <div class="d-flex gap-2 mt-4">
                @Html.ActionLink("Editar", "Edit", new { id = Model.IdPaciente }, new { @class = "btn btn-primary rounded-pill px-4" })
                @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary rounded-pill px-4" })
            </div>
        </div>
    </div>
</div>
